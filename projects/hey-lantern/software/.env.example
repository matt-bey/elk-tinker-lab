OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Wake word: a pre-trained model name (e.g. hey_jarvis, alexa) or path to a custom .onnx file
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.5

# Seconds of silence before the conversation session resets
SESSION_TIMEOUT=30

# Set to false to skip TTS playback (useful when no speaker is connected)
TTS_ENABLED=true
